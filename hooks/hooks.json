{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$CLAUDE_PROJECT_DIR/.claude/skills\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$CLAUDE_PROJECT_DIR/.playwright-mcp/\"*.png 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
